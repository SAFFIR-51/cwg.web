# Copy to .env and fill in real values. NEVER commit the real .env.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
# Gmail App Password (16 chars). Create at https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# Where inquiry emails are delivered (comma-separate for multiple)
MAIL_TO=your-account@gmail.com
# Display name shown as the sender
MAIL_FROM_NAME=FULIF Ad Partner Inquiry

# Local server bind
HOST=127.0.0.1
PORT=8000
